{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Next Note Schema",
  "description": "Schema for structured NEXT note data with projects and action items",
  "type": "object",
  "properties": {
    "note_id": {
      "type": "string",
      "description": "Unique identifier of the note"
    },
    "note_date": {
      "type": "string",
      "format": "date",
      "description": "Date when the note was created (ISO format)"
    },
    "formatted_date": {
      "type": "string",
      "description": "Formatted date string (d/m)"
    },
    "projects": {
      "type": "array",
      "description": "List of projects with their action items",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the project"
          },
          "items": {
            "type": "array",
            "description": "List of action items for this project",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string",
                  "description": "Text of the action item"
                },
                "completed": {
                  "type": "boolean",
                  "description": "Whether the action item is completed"
                }
              },
              "required": ["text", "completed"]
            }
          }
        },
        "required": ["name", "items"]
      }
    },
    "raw_text": {
      "type": "string",
      "description": "Original raw text of the note"
    }
  },
  "required": ["note_id", "note_date", "formatted_date", "projects", "raw_text"]
}
